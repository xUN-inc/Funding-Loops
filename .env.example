# Postgres connection string for the CRA / FED / AB / general schemas.
# SSL is forced; the app uses { rejectUnauthorized: false } for hosted DBs.
DATABASE_URL=postgres://user:password@host:5432/database

# Google AI Studio key for Gemini memo generation.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Optional ---

# Override the Gemini model. Defaults to gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-pro

# If set, /api/summary/narrative tries Claude first, then falls back to Gemini.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-20250514

# Server port. Default 3000.
# PORT=3000
